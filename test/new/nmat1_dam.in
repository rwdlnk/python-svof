# NMAT=1 dam-break test case
# Simple rectangular fluid column (left half, bottom half)
# Free-slip walls, no surface tension, no disturbance

mesh
0     # icyl (0=planar)
1 1   # NKX NKY
0.05  # XC (1D array, NKX long)
20    # NXL (1D array, NKX long)
20    # NXR (1D array, NKX long)
0.0025 # DXmin (1D array, NKX long)
0.05  # YC (1D array, NKY long)
20    # NYL (1D array, NKY long)
20    # NYR (1D array, NKY long)
0.0025 # DYmin (1D array, NKY long)
0.0 0.1 # XL (1D array, NKX+1 long)
0.0 0.1 # YL (1D array, NKY+1 long)
1 42 1 22 # IFL IFR JFB JFT (left half, bottom half of 40x40 grid)

properties
1 # NMAT (free surface)
1.0e-6 1.5e-5 # NU NUC (water viscosity, air viscosity)
1000.0 1.0 # RHOF RHOFC (water density, void uses small density)
False 0.0 90.0 # ISURF10 sigma cangle (no surface tension)

output
True False False # IPLOTS IARE IMOVY
100.0 # PRTDT
0.0 1.0 # PLTST1 PLTST2
0.01 0.01 # PLTDT1 PLTDT2
dam-  # PREFIX (output filename prefix)

bcs
1 1 1 1 # WL WR WT WB (all free-slip)

particles
0 0 # NPX NPY
0.0 0.0 # XPL XPR
0.0 0.0 # YPB YPT

obstacles
0 # NOBS
1 1 # IOMIN IOMAX (placeholders)
1 1 # JOMIN JOMAX

disturb
0   # NDIS (no disturbance)
0   # IDIS
0.0 # VORIG
0.1 0.05 1 1 # R H ILOW IHIGH (placeholders)

svof
0.025 # EPSI
1.7   # OMG
1.0   # ALPHA
0.0 -9.81 # Gx Gy
0.0 0.0   # UI VI
-1.0      # CSQ
1. 1. 1.  # Fmass Flength Ftime
False 0.0 # ISHvel SHvel
0.0001 1.0 # DELT AUTOT (auto time stepping)
0.1  # TWfin
